# hookhq SDK Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# Security Configuration
# The SDK supports loading security credentials from environment variables
# with the prefix: HOOKHQ_
#
# Security environment variables:
HOOKHQ_BEARER_AUTH=your_bearerauth_here
HOOKHQ_API_KEY_COOKIE=your_apikeycookie_here

# Debug Configuration
# Enable HTTP request/response logging for debugging
HOOKHQ_DEBUG=true
