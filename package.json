{
  "name": "webhooks",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "clean": "rm -rf .open-next && rm -rf .wrangler && rm -rf node_modules && rm -rf .next",
    "clean-deploy": "pnpm clean && pnpm i && pnpm run deploy",
    "dev": "wrangler d1 migrations apply DATABASE --local && next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "deploy": "opennextjs-cloudflare build && npx wrangler d1 migrations apply DATABASE --remote; opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "auth:generate": "npx --yes @better-auth/cli@latest generate --config src/auth/index.ts --output src/db/auth.schema.ts -y",
    "auth:format": "npx --yes prettier --write src/db/auth.schema.ts",
    "auth:update": "npm run auth:generate && npm run auth:format",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "wrangler d1 migrations apply DATABASE --local",
    "db:migrate:prod": "wrangler d1 migrations apply DATABASE --remote",
    "db:studio:dev": "drizzle-kit studio",
    "db:studio:prod": "NODE_ENV=production drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "docs:generate": "npx next-swagger-doc-cli next-swagger-doc.json --output src/lib/openapi.json"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@scalar/nextjs-api-reference": "^0.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "^1.2.7",
    "better-auth-cloudflare": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.43.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.509.0",
    "next": "15.3.1",
    "next-swagger-doc": "0.4.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250813.0",
    "@opennextjs/cloudflare": "^1.6.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.37.1"
  },
  "cloudflare": {
    "bindings": {
      "AUTH_SECRET": {
        "description": "Generate a random string using `openssl rand -base64 32`. Required."
      },
      "NEXT_PUBLIC_API_DOCS_ENABLED": {
        "description": "Whether to enable public API docs at /api and /api/auth/reference. Default is 'true'."
      },
      "JWT_PREFIX": {
        "description": "Prefix of the JWT issuer / audience. Default is 'hookhq'."
      }
    }
  }
}
